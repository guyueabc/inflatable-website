[Unit]
Description=InflatableModel Main Website (US)
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/inflatable-website
EnvironmentFile=/opt/inflatable-website/.env
ExecStart=/opt/inflatable-website/venv/bin/gunicorn -w 4 -b 127.0.0.1:8000 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
