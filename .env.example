# ── Hunyuan 3D API ───────────────────────────────────────────────────────────
HUNYUAN_API_KEY=
HUNYUAN_ENDPOINT=https://api.ai3d.cloud.tencent.com
HUNYUAN_MODEL=3.0

# ── HK Proxy (dual-node mode) ────────────────────────────────────────────────
# Leave both empty for single-node mode.
# In dual-node mode, set HUNYUAN_PROXY_URL to the CloudFlare Tunnel domain
# that points to your HK proxy server.
HUNYUAN_PROXY_URL=
HUNYUAN_PROXY_SECRET=

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_SECRET_KEY=

# ── SMTP (Aliyun Enterprise Email) ──────────────────────────────────────────
MAIL_SERVER=smtp.mxhichina.com
MAIL_PORT=465
MAIL_USERNAME=dulizhan@showlovein.com
MAIL_PASSWORD=

# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Admin ────────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=
